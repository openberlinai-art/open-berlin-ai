{
  "name": "kulturpulse-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":    "wrangler dev",
    "deploy": "wrangler deploy",
    "lint":   "tsc --noEmit",
    "migrate:local":  "wrangler d1 execute kulturpulse-db --local --file=../schema.sql",
    "migrate:remote": "wrangler d1 execute kulturpulse-db --remote --file=../schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0"
  }
}
