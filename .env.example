# ── Cloudflare Worker ──────────────────────────────────────────────────────────
# Wrangler uses these during `wrangler deploy` and `wrangler dev`
# Set via `wrangler secret put` for production, or .dev.vars for local dev

# Secret used to protect the /api/ingest endpoint
INGEST_SECRET=change-me-before-deploy

# Origin(s) allowed in CORS header (comma-separated for multiple)
ALLOWED_ORIGIN=https://kulturpulse-berlin.vercel.app

# ── Next.js web app ────────────────────────────────────────────────────────────
# Used server-side (in API routes / RSC) to call the Worker
WORKER_API_URL=https://kulturpulse-worker.your-subdomain.workers.dev

# Used client-side (browser) — must start with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=https://kulturpulse-worker.your-subdomain.workers.dev

# ── GitHub Actions secrets ─────────────────────────────────────────────────────
# Set these in your repo → Settings → Secrets and variables → Actions:
#
# CLOUDFLARE_API_TOKEN   — Cloudflare API token with Worker+D1 edit permissions
# CLOUDFLARE_ACCOUNT_ID  — Your Cloudflare account ID
# VERCEL_TOKEN           — Vercel personal access token
# VERCEL_ORG_ID          — `vercel link` outputs this
# VERCEL_PROJECT_ID      — `vercel link` outputs this
